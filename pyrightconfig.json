{
    "include": [
        "backend",
        "frontend"
    ],
    "exclude": [
        "**/node_modules",
        "**/__pycache__",
        ".venv"
    ],
    "venvPath": "backend",
    "venv": ".venv",
    "executionEnvironments": [
        {
            "root": "backend",
            "extraPaths": [
                "backend"
            ]
        }
    ],
    "pythonVersion": "3.14",
    "typeCheckingMode": "basic",
    "reportMissingImports": true,
    "reportMissingTypeStubs": false
}
